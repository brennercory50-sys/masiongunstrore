# Copy this file to .env and fill in your values

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# NextAuth
NEXTAUTH_SECRET=generate-a-random-32-character-secret
NEXTAUTH_URL=https://your-domain.com

# AWS S3
AWS_PROFILE=hosted_storage
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=your-prefix/

# Abacus AI (notifications)
ABACUSAI_API_KEY=your-api-key
WEB_APP_ID=your-app-id
NOTIF_ID_SELL_FIREARM_SUBMISSION=your-notif-id
NOTIF_ID_ITEM_REQUEST_SUBMISSION=your-notif-id
NOTIF_ID_PAWN_LOAN_REQUEST=your-notif-id

# Notification settings
NOTIFICATION_RECIPIENT_EMAIL=admin@example.com
